<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dudu.gtm-weibo-worker</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/Users/dudu/Desktop/trae/重点日常项目/【GTM】新机售价监控分析系统/scripts/weibo-local-worker.mjs</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/dudu/Desktop/trae/重点日常项目/【GTM】新机售价监控分析系统</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/dudu/.local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>StandardOutPath</key>
  <string>/tmp/gtm-weibo-worker.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/gtm-weibo-worker.error.log</string>
</dict>
</plist>
