# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Browser Use CLI only runs on the local Worker and reuses this machine's
# logged-in Chrome. The cloud server only queues jobs and processes returned JSON.
BROWSER_USE_CLI_PATH="browser-use"
BROWSER_USE_MODE="local"
BROWSER_USE_TIMEOUT_MS="480000"
WEIBO_SOURCE_UID="7928198622"
WEIBO_LOOKBACK_DAYS="21"
WEEKLY_SALES_AUTOMATION_TOKEN="replace-with-strong-token"
WEEKLY_SALES_WORKER_TOKEN="replace-with-a-different-strong-token"
WEEKLY_SALES_SCHEDULE_ENABLED="false"
WEEKLY_SALES_SCHEDULE_TIMEZONE="Asia/Shanghai"
GTM_SERVER_URL="http://127.0.0.1:8787"
GTM_WORKER_ID="dudu-mac"
GTM_WORKER_POLL_MS="15000"

# Daily price BI lookup API used by the production server.
# If the daily-price service runs directly on the same Docker host at 8765,
# docker-compose can use host.docker.internal via host-gateway.
DAILY_PRICE_LOOKUP_URL="http://host.docker.internal:8765/api/lookup"

# Daily price Excel upload/import endpoint exposed by Caddy:
# https://www.gtmdudu.xyz/api/daily-price/import-excel
# It reuses the token mounted at DAILY_PRICE_TOKEN_PATH.

# Comma-separated bearer tokens for the read-only MCP server.
# Example client header: Authorization: Bearer <token>
MCP_API_TOKENS="replace-with-strong-token"

# Comma-separated allowed browser origins for MCP Streamable HTTP requests.
# Server-to-server MCP clients often do not send an Origin header.
MCP_ALLOWED_ORIGINS="https://mcp.gtmdudu.xyz"

# Local MCP server binds to 127.0.0.1 by default. Docker Compose overrides this to 0.0.0.0.
MCP_HOST="127.0.0.1"
