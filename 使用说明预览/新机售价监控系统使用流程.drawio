<mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="新机售价监控系统使用流程" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F97316;strokeColor=#EA580C;fontColor=#FFFFFF;fontSize=24;fontStyle=1;arcSize=18;" vertex="1" parent="1"><mxGeometry x="200" y="30" width="400" height="60" as="geometry"/></mxCell><mxCell id="3" value="适用于：查看概览、输出汇总、检索明细、更新原始数据并同步重算" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#FDBA74;fontColor=#9A3412;fontSize=13;arcSize=18;" vertex="1" parent="1"><mxGeometry x="165" y="100" width="470" height="38" as="geometry"/></mxCell><mxCell id="10" value="1&#xa;打开网站" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FDBA74;fontColor=#1F2937;fontSize=20;fontStyle=1;arcSize=20;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="190" width="180" height="100" as="geometry"/></mxCell><mxCell id="11" value="访问系统首页，先确认当前最新数据日期。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#FED7AA;fontColor=#4B5563;fontSize=13;arcSize=18;" vertex="1" parent="1"><mxGeometry x="50" y="295" width="180" height="70" as="geometry"/></mxCell><mxCell id="12" value="2&#xa;查看概览" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FDBA74;fontColor=#1F2937;fontSize=20;fontStyle=1;arcSize=20;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="190" width="180" height="100" as="geometry"/></mxCell><mxCell id="13" value="先看概览卡片和型号系列透视表，快速判断近期波动。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#FED7AA;fontColor=#4B5563;fontSize=13;arcSize=18;" vertex="1" parent="1"><mxGeometry x="300" y="295" width="180" height="70" as="geometry"/></mxCell><mxCell id="14" value="3&#xa;阅读汇总" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FDBA74;fontColor=#1F2937;fontSize=20